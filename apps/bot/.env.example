# Telegram Bot
BOT_TOKEN=your_bot_token_here
WEBHOOK_URL=https://your-backend.onrender.com/webhook
WEBHOOK_SECRET=your_random_secret_here

# Upstash Redis
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your_upstash_token_here

# Dispatch Supergroup (public, topics enabled)
DISPATCH_GROUP_ID=-100xxxxxxxxxx
DISPATCH_GROUP_USERNAME=your_group_username

# Frontend
FRONTEND_URL=https://your-frontend.vercel.app

# Server
PORT=3000

# Matchmaking
MATCH_FEE_STARS=150
QUEUE_TIMEOUT_MS=900000
BLACKLIST_TTL_SECONDS=259200
